{
  "manifest_version": 2,
  "name": "Chat Tree",
  "version": "0.1.0",
  "description": "Tree visualizer for branched ChatGPT conversations",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["inject.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": ["content.js"],
  "browser_specific_settings": {
    "gecko": {
      "id": "chat-tree@tree-convo"
    }
  }
}
