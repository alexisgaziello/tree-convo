{
  "name": "tree-convo",
  "version": "1.0.0",
  "description": "Browser extension and userscript that visualizes ChatGPT conversation branches as an interactive SVG tree",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config builds/tampermonkey/vite.config.ts",
    "build": "pnpm build:tampermonkey",
    "build:tampermonkey": "vite build --config builds/tampermonkey/vite.config.ts",
    "build:chrome": "vite build --config builds/chrome/vite.config.ts",
    "build:firefox": "vite build --config builds/firefox/vite.config.ts",
    "build:all": "pnpm build:tampermonkey && pnpm build:chrome && pnpm build:firefox",
    "build:watch": "vite build --watch --config builds/tampermonkey/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "keywords": [
    "tampermonkey",
    "userscript",
    "chatgpt",
    "tree",
    "typescript",
    "vite"
  ],
  "author": "Alexis Gaziello <alexis.gaziello@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.30.0",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-monkey": "^7.1.9",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "d3-hierarchy": "^3.1.2"
  }
}
